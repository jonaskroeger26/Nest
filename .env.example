# Required for Nest: public Solana RPC often returns 403. Use Helius (free tier).
# 1. Sign up at https://helius.dev and create an app
# 2. Copy your API key and paste it below, then: cp .env.example .env.local

# Mainnet RPC (used for both plain SOL and mSOL vaults)
NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Without these set, the app returns 503 and asks you to set them.

# Optional: Helius Enhanced Transactions API (for transaction history — not used for send/blockhash)
# HELIUS_TRANSACTIONS_API=https://api-mainnet.helius-rpc.com/v0/transactions/?api-key=YOUR_HELIUS_API_KEY