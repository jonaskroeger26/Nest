# Optional: use a dedicated RPC to avoid 403 rate limits from public endpoints.
# Both plain SOL and mSOL vaults use mainnet.

NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com
SOLANA_RPC_MAINNET=https://api.mainnet-beta.solana.com

# Example with Helius (replace YOUR_KEY):
# NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
