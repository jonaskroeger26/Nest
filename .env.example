# Copy to .env.local: cp .env.example .env.local

# === Stay on testnet until everything works ===
# Default cluster is testnet. Do NOT set mainnet-beta on Vercel until you deploy
# kids-vault on mainnet. Phantom must match (Testnet). Program 3be5xt = testnet.

# ---------------------------------------------------------------------------
# Testnet (recommended for trying vaults without real SOL)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SOLANA_CLUSTER=testnet
# Optional: custom RPC (default is https://api.testnet.solana.com)
# SOLANA_RPC_TESTNET=https://api.testnet.solana.com

# Program ID after: anchor deploy -p kids_vault --provider.cluster testnet
# (Default matches repo keypair in target/deploy/kids_vault-keypair.json)
NEXT_PUBLIC_KIDS_VAULT_PROGRAM_ID=3be5xtB1AUiCxQ3dPn8bEt95VrzzEEW2cJym2wXo4rnN

# ---------------------------------------------------------------------------
# Mainnet (production)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta
# NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# NEXT_PUBLIC_KIDS_VAULT_PROGRAM_ID=<same ID after you deploy to mainnet with the same keypair>

# Optional: Helius Enhanced Transactions API
# HELIUS_TRANSACTIONS_API=https://api-mainnet.helius-rpc.com/v0/transactions/?api-key=YOUR_HELIUS_API_KEY

# Supabase (if used)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Auto-save (relayer + on-chain escrow) — optional
# ---------------------------------------------------------------------------
# After upgrading kids-vault with auto-save instructions, set the relayer keypair
# (JSON byte array, same format as Phantom export / solana-keygen).
# NEST_AUTOSAVE_RELAYER_SECRET=[173,1,2,...]
# Cron / manual trigger: Authorization: Bearer <secret>
# NEST_AUTOSAVE_CRON_SECRET=your-long-random-string
# Public key of that keypair (shown in UI; must match init tx relayer arg)
# NEXT_PUBLIC_NEST_AUTOSAVE_RELAYER_PUBKEY=
